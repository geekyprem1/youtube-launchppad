# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
# Vision model for thumbnail analysis (supports images)
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-exp:free

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# App URL (for OpenRouter referer header)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SiliconFlow API (For Thumbnail Engine Image Generation)
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_IMAGE_MODEL=Tongyi-MAI/Z-Image-Turbo
